# --- Postgres (used by docker-compose and the app) ---
POSTGRES_USER=leads
POSTGRES_PASSWORD=leads
POSTGRES_DB=leads
LEADS_DATABASE_URL=postgresql+asyncpg://leads:leads@postgres:5432/leads
LEADS_DB_POOL_SIZE=10
LEADS_DB_MAX_OVERFLOW=20
LEADS_DB_ECHO=false

# --- Redis (kept for caching, no longer used for event streams) ---
LEADS_REDIS_URL=redis://redis:6379/0

# --- HTTP Fetch Layer ---
LEADS_HTTP_DEFAULT_TIMEOUT_SEC=30
LEADS_HTTP_MAX_RETRIES=3
LEADS_HTTP_USER_AGENT_REDDIT=lead-pipeline/1.0 (by /u/your_username)
LEADS_HTTP_USER_AGENT_DEFAULT=lead-pipeline/1.0

# --- Browser Fetch (optional — requires pip install "lead-pipeline[browser]") ---
LEADS_ENABLE_BROWSER_FETCHER=false
LEADS_BROWSER_RESTART_AFTER_PAGES=100
LEADS_BROWSER_PAGE_TIMEOUT_SEC=30
LEADS_BROWSER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# --- Reddit Adapter ---
LEADS_REDDIT_SUBREDDITS=["startups","SaaS","webdev"]
LEADS_REDDIT_POLL_INTERVAL_SECONDS=300
LEADS_REDDIT_POST_LIMIT=25

# --- HackerNews Adapter ---
LEADS_HN_POLL_INTERVAL_SECONDS=600

# --- Wellfound Adapter (requires ENABLE_BROWSER_FETCHER=true) ---
LEADS_WELLFOUND_POLL_INTERVAL_SECONDS=3600
LEADS_WELLFOUND_SEARCH_ROLES=["developer","engineer"]

# --- ProductHunt Adapter ---
LEADS_PRODUCTHUNT_POLL_INTERVAL_SECONDS=21600

# --- Generic RSS Feeds (empty = disabled) ---
LEADS_RSS_FEED_URLS=[]
LEADS_RSS_MULTI_POLL_INTERVAL_SECONDS=1800

# --- Google Custom Search Engine (empty key = disabled) ---
LEADS_GOOGLE_CSE_API_KEY=
LEADS_GOOGLE_CSE_ENGINE_ID=
LEADS_GOOGLE_CSE_QUERIES=["site:reddit.com hiring developer","startup looking for developer"]
LEADS_GOOGLE_CSE_POLL_INTERVAL_SECONDS=21600
LEADS_GOOGLE_CSE_DAILY_QUERY_BUDGET=100

# --- LinkedIn Adapter (RapidAPI — empty key = disabled) ---
LEADS_LINKEDIN_RAPIDAPI_KEY=
LEADS_LINKEDIN_RAPIDAPI_HOST=fresh-linkedin-profile-data.p.rapidapi.com
LEADS_LINKEDIN_JOB_QUERIES=["python developer","fastapi engineer","react developer"]
LEADS_LINKEDIN_POST_QUERIES=["hiring developer","looking for engineer","need a CTO"]
LEADS_LINKEDIN_POLL_INTERVAL_SECONDS=14400

# --- Funding Sources ---
LEADS_FUNDING_FEED_URLS=["https://techcrunch.com/category/fundraising/feed/","https://news.crunchbase.com/feed/"]
LEADS_FUNDING_POLL_INTERVAL_SECONDS=43200

# --- Circuit Breaker (scraping) ---
LEADS_CIRCUIT_BREAKER_THRESHOLD=3
LEADS_CIRCUIT_BREAKER_COOLDOWN_SECONDS=3600

# --- Graceful Shutdown ---
LEADS_SHUTDOWN_TIMEOUT_SECONDS=30

# --- Logging ---
LEADS_LOG_LEVEL=INFO
LEADS_LOG_JSON=true

# --- LLM Provider ---
LEADS_LLM_PROVIDER=anthropic          # "anthropic" or "openai"
LEADS_ANTHROPIC_API_KEY=sk-ant-...your-key-here...
LEADS_LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
LEADS_LLM_MODEL_SMART=claude-sonnet-4-6
LEADS_OPENAI_API_KEY=sk-...your-key-here...
LEADS_OPENAI_MODEL_CHEAP=gpt-4o-mini
LEADS_OPENAI_MODEL_SMART=gpt-4o
LEADS_DAILY_LLM_BUDGET_USD=10.0

# --- Enrichment (set to true when you have an LLM API key) ---
LEADS_ENABLE_ENRICHMENT=false
LEADS_MAX_CONCURRENT_ENRICHMENTS=5
LEADS_USER_SKILLS=["python","fastapi","react","typescript","postgres"]

# --- Event Bus ---
LEADS_EVENT_BUS_QUEUE_SIZE=1000

# --- Resweeper ---
LEADS_RESWEEPER_INTERVAL_SECONDS=300
